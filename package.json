{
  "name": "server-monitor",
  "version": "1.0.0",
  "description": "A local Windows desktop app for remote monitoring of Linux servers via SSH",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build && tsc -p tsconfig.node.json",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "package": "npm run build && electron-builder",
    "package:portable": "npm run build && electron-builder --win portable",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "antd": "^5.21.0",
    "recharts": "^2.12.0",
    "zustand": "^4.5.0",
    "dayjs": "^1.11.0",
    "uuid": "^10.0.0",
    "better-sqlite3": "^11.2.0",
    "ssh2": "^1.15.0",
    "electron-log": "^5.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "wait-on": "^7.2.0"
  }
}
